# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).

# ── LLM provider: nvidia (free, default) | groq | ollama (local) ──
LLM_PROVIDER=nvidia
NVIDIA_API=nvapi-xxxxxxxx
GROQ_API=gsk_xxxxxxxx                 # only needed if LLM_PROVIDER=groq

# ── Job search (RapidAPI JSearch) ──
JSearch_API=xxxxxxxx

# ── Supabase: auth + run history + file storage ──
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxx   # service_role/secret key — BACKEND ONLY
SUPABASE_BUCKET=deliverables

# ── Auth: JWT signing secret (generate a random 48+ char string) ──
JWT_SECRET=change-me-to-a-long-random-string

# ── Redis: rate limiting ──
REDIS_URL=redis://localhost:6379
